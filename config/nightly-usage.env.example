# Copy to config/nightly-usage.env and fill in real values.

# Required for all runs
MIXPANEL_TOKEN=your_mixpanel_project_token

# Required for live publish (choose one auth mode)
# 1) Legacy API secret auth
MIXPANEL_API_SECRET=
# 2) Service account auth
MIXPANEL_SERVICE_ACCOUNT_USER=
MIXPANEL_SERVICE_ACCOUNT_PASS=

# Optional pipeline tuning
MIXPANEL_ENDPOINT=https://api.mixpanel.com/import
MIXPANEL_DISTINCT_ID=session-metrics-cron
MIXPANEL_TIMEZONE=UTC
MIXPANEL_BATCH_SIZE=2000
MAX_EVENTS_PER_FAMILY=100000
MAX_UNIQUE_PROMPT_HASHES_PER_DAY=50000
MAX_STATE_IDS=500000

# Optional override for logs and state
USAGE_PIPELINE_LOG_DIR=$HOME/.session-metrics-cron/usage-metrics
USAGE_PIPELINE_SOURCES_CONFIG=$PWD/config/sources.json
USAGE_TASK_CATEGORIZATION_CONFIG=$PWD/config/task-categorization.yaml
USAGE_TASK_CLASSIFICATION_CACHE=$HOME/.session-metrics-cron/usage-metrics/task-classification-cache.json

# Optional: force replay mode (ignore local state suppression)
# Useful when backfilling after partial failures. Mixpanel dedupe still relies
# on stable $insert_id values emitted by the exporter.
USAGE_PIPELINE_IGNORE_LOCAL_STATE=0
