TZ=Asia/Hong_Kong
BENCHMARK_ROOT=/home/invoker/invoker-benchmarks
INVOKER_REPO=https://github.com/Neko-Catpital-Labs/Invoker.git
INVOKER_BRANCH=master
CORPUS_DIR=/home/invoker/invoker-benchmarks/corpus/submit-to-invoker-sessions-2026-05-26
MODELS=codex
MODES=invoker_workflow,invoker_auto_fix
WORKER_CONCURRENCY_PER_HOST=1
BENCHMARK_SERIAL_JOBS=1
BENCHMARK_EMIT_MIXPANEL_DEFAULT=0

# Match direct /plan-to-invoker scans by giving Codex the same prompt text:
# /plan-to-invoker, the conversion instruction, and the full session JSONL.
BENCHMARK_PLAN_PROMPT_SOURCE=plan_to_invoker_direct
BENCHMARK_MAX_PROMPT_CHARS=500000

BENCHMARK_PLAN_CODEX_COMMAND='{ cat "$PROMPT_FILE"; printf "\n\nRequired benchmark output constraint: the final YAML must include mergeMode: manual.\n"; } | codex exec --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox - > "$GENERATED_PLAN"'
BENCHMARK_PLAN_CLAUDE_COMMAND='claude -p "$(cat "$PROMPT_FILE")"$'\''\n\nRequired benchmark output constraint: the final YAML must include mergeMode: manual.'\'' > "$GENERATED_PLAN"'
