# Copy to /home/invoker/invoker-benchmarks/config/benchmark.env on the coordinator.

TZ=Asia/Hong_Kong
BENCHMARK_ROOT=/home/invoker/invoker-benchmarks
INVOKER_REPO=https://github.com/Neko-Catpital-Labs/Invoker.git
INVOKER_BRANCH=master
CORPUS_DIR=/home/invoker/invoker-benchmarks/corpus/submit-to-invoker-sessions-2026-05-26
MODELS=codex,claude
MODES=baseline_direct,invoker_workflow,invoker_auto_fix
WORKER_CONCURRENCY_PER_HOST=1
MIXPANEL_PROJECT_ID=4027782
MIXPANEL_SCHEMA_VERSION=invoker_benchmark_v1
BENCHMARK_PRICING_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json
# No-arg nightly runs publish by default. Use --no-emit-mixpanel or set this to
# 0 for a local-only run that still writes mixpanel-export.jsonl.
BENCHMARK_EMIT_MIXPANEL_DEFAULT=1

# Required only when emitting to Mixpanel.
MIXPANEL_TOKEN=
MIXPANEL_ENDPOINT=https://api.mixpanel.com/import
MIXPANEL_SERVICE_ACCOUNT_USER=
MIXPANEL_SERVICE_ACCOUNT_PASS=
MIXPANEL_API_SECRET=

# Optional command templates evaluated by run-worker-job.sh.
# Available variables: CHECKOUT_DIR, CONVERSATION_FILE, PROMPT_FILE, MODEL,
# MODE, JOB_DIR, GENERATED_PLAN, INVOKER_SHA, INVOKER_AUTOFIX.
#
# BENCHMARK_CHECKOUT_SETUP_COMMAND='pnpm -r --if-present build'
# BENCHMARK_BASELINE_CODEX_COMMAND='codex exec --skip-git-repo-check - < "$PROMPT_FILE"'
# BENCHMARK_BASELINE_CLAUDE_COMMAND='claude -p "$(cat "$PROMPT_FILE")"'
# BENCHMARK_PLAN_CODEX_COMMAND='{ printf "/plan-to-invoker\n"; cat "$PROMPT_FILE"; } | codex exec --skip-git-repo-check - > "$GENERATED_PLAN"'
# BENCHMARK_PLAN_CLAUDE_COMMAND='claude -p /plan-to-invoker < "$PROMPT_FILE" > "$GENERATED_PLAN"'
# Default Invoker submission uses the checked-out repo:
# INVOKER_DB_DIR="$JOB_DIR/invoker-db" ./run.sh --headless run "$GENERATED_PLAN"
# Override only for local debugging or emergency coordinator workarounds.
# BENCHMARK_INVOKER_SUBMIT_COMMAND='./run.sh --headless run "$GENERATED_PLAN"'
